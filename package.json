{
  "name": "desktop-panel",
  "version": "1.0.9",
  "description": "Desktop floating panel built with Electron",
  "main": "electron/main.js",
  "scripts": {
    "start": "npm run dev",
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:web": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:electron": "wait-on tcp:127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron electron/main.js",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder --win nsis",
    "preview": "vite preview --host 127.0.0.1 --port 4173 --strictPort"
  },
  "build": {
    "appId": "com.flowerdrunk.minidesktool",
    "productName": "Mini Desk Tool",
    "compression": "maximum",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "files": [
      "electron/**/*",
      "renderer-dist/**/*",
      "build/icon.ico",
      "README.md",
      "README.zh-CN.md",
      "package.json"
    ],
    "asar": true,
    "win": {
      "icon": "build/icon.ico",
      "artifactName": "${productName} Setup ${version}.${ext}",
      "electronLanguages": [
        "zh-CN",
        "en-US"
      ],
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "vite": "^7.1.7",
    "wait-on": "^8.0.5"
  },
  "dependencies": {
    "windows-shortcuts": "^0.1.6"
  }
}
