{
  "name": "desktop-panel",
  "version": "1.0.4",
  "description": "Desktop floating panel built with Electron",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.flowerdrunk.minidesktool",
    "productName": "Mini Desk Tool",
    "compression": "maximum",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "script.js",
      "styles.css",
      "build/icon.ico",
      "README.md",
      "README.zh-CN.md",
      "package.json"
    ],
    "asar": true,
    "win": {
      "icon": "build/icon.ico",
      "artifactName": "${productName} Setup ${version}.${ext}",
      "electronLanguages": [
        "zh-CN",
        "en-US"
      ],
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "windows-shortcuts": "^0.1.6"
  }
}
