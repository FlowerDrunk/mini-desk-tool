{
  "name": "desktop-panel",
  "version": "1.2.0",
  "description": "Desktop floating panel built with Tauri",
  "scripts": {
    "start": "npm run dev",
    "dev": "node scripts/run-tauri.js dev",
    "dev:web": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "build:renderer": "vite build",
    "build": "node scripts/run-tauri.js build",
    "preview": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2.10.1",
    "vite": "^7.1.7"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1"
  }
}
