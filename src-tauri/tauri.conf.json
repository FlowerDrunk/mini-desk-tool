{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Mini Desk Tool",
  "version": "1.2.3",
  "identifier": "com.flowerdrunk.minidesktool",
  "build": {
    "frontendDist": "../renderer-dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:renderer"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Desktop Panel",
        "width": 360,
        "height": 720,
        "minWidth": 300,
        "minHeight": 460,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "skipTaskbar": true,
        "alwaysOnTop": false,
        "visible": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEzOTg1OEZDNDRBRkEyQjMKUldTem9xOUUvRmlZRTlqcm5GbjlJUGNlMkpBdUQwc3NLNUNzNmNOVG5IOVEydXZLcThORkVyM2gK",
      "endpoints": [
        "https://github.com/FlowerDrunk/mini-desk-tool/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
